<?php
/**
 * Dashboard Principal - Versión Dinámica
 * Lee gráficos configurados desde BD
 */

require_once 'config.php';
requireLogin();

require_once 'models/Area.php';
require_once 'models/Periodo.php';
require_once 'models/Metrica.php';
require_once 'models/ValorMetrica.php';
require_once 'models/Grafico.php';

// Obtener área y período de la URL
$area_actual = isset($_GET['area']) ? (int)$_GET['area'] : AREA_SOFTWARE;
$periodo_str = $_GET['periodo'] ?? getCurrentPeriod();

// Instanciar modelos
$areaModel = new Area();
$periodoModel = new Periodo();
$metricaModel = new Metrica();
$valorModel = new ValorMetrica();
$graficoModel = new Grafico();

// Obtener datos del área
$area = $areaModel->getById($area_actual);
if (!$area) {
    redirect('/index.php');
}

// Obtener período
list($ejercicio, $periodo_mes) = explode('-', $periodo_str);
$periodo = $periodoModel->getByEjercicioPeriodo($ejercicio, $periodo_mes);
if (!$periodo) {
    redirect('/index.php');
}

$periodo_seleccionado = $periodo_str;

// Obtener todas las áreas
$areas = $areaModel->getActivas();

// Obtener últimos períodos para el selector
$periodos = $periodoModel->getRecientes(12);

// Obtener métricas del área con valores
$metricas = $metricaModel->getByAreaConValores($area_actual, $periodo['id']);

// Obtener gráficos configurados para esta área
$rol_usuario = $_SESSION['user_role'] ?? 'viewer';
$graficos_configurados = $graficoModel->getByArea($area_actual, true, $rol_usuario);

// Variables para header
$page_title = 'Dashboard - ' . $area['nombre'];
$is_admin = isAdmin();
$area_color = $area['color'];
$periodo_nombre = $periodo['nombre'];

/**
 * Función helper para obtener datos de una métrica específica
 */
function obtenerDatosMetrica($metrica_id, $periodo_id, $metricaModel, $valorModel) {
    global $metricas;
    
    // Buscar en las métricas ya cargadas
    foreach ($metricas as $m) {
        if ($m['id'] == $metrica_id) {
            return $m;
        }
    }
    
    // Si no está en caché, cargar directamente
    $metrica = $metricaModel->getById($metrica_id);
    if (!$metrica) return null;
    
    $valores = $valorModel->getByMetricaYPeriodo($metrica_id, $periodo_id);
    $metrica['valor'] = $valores['valor'] ?? null;
    $metrica['valor_anterior'] = $valores['valor_anterior'] ?? null;
    $metrica['nota'] = $valores['nota'] ?? null;
    
    return $metrica;
}

/**
 * Función helper para obtener datos históricos de una métrica
 */
function obtenerHistoricoMetrica($metrica_id, $periodos_cantidad, $periodo_id, $metricaModel, $periodoModel, $valorModel) {
    // Usar el método del modelo
    $historico = $valorModel->getHistorico($metrica_id, $periodos_cantidad);
    
    // Si no hay datos, intentar obtener con el método anterior
    if (empty($historico)) {
        // Obtener los últimos N períodos
        $periodos_list = $periodoModel->getRecientes($periodos_cantidad);
        
        $historico = [];
        foreach ($periodos_list as $p) {
            $valor_data = $valorModel->getByMetricaYPeriodo($metrica_id, $p['id']);
            
            $historico[] = [
                'periodo_nombre' => $p['nombre'],
                'fecha' => $p['ejercicio'] . '-' . str_pad($p['periodo'], 2, '0', STR_PAD_LEFT) . '-01',
                'valor' => $valor_data['valor'] ?? 0,
                'nombre' => $valor_data['metrica_nombre'] ?? '',
                'metrica_nombre' => $valor_data['metrica_nombre'] ?? ''
            ];
        }
    }
    
    return $historico;
}
?>

<?php include 'partials/header.php'; ?>
<?php include 'partials/navbar.php'; ?>

<!-- Dashboard Principal -->
<div class="page-body">
    <div class="container-xl">
        
        <!-- Header con título y botones admin -->
        <div class="page-header mb-4">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title" style="color: <?php echo $area['color']; ?>">
                        <i class="ti ti-<?php echo $area['icono']; ?> me-2"></i>
                        <?php echo $area['nombre']; ?>
                    </h2>
                    <div class="text-muted mt-1"><?php echo $periodo['nombre']; ?></div>
                </div>
                <div class="col-auto">
                    <?php if ($is_admin): ?>
                        <div class="btn-group">
                            <a href="<?php echo BASE_URL; ?>/admin/metricas.php?area=<?php echo $area_actual; ?>&periodo=<?php echo $periodo_seleccionado; ?>" 
                               class="btn btn-primary">
                                <i class="ti ti-edit me-1"></i>
                                Administrar Métricas
                            </a>
                            <a href="<?php echo BASE_URL; ?>/admin/configurar-graficos.php?area=<?php echo $area_actual; ?>" 
                               class="btn btn-outline-primary">
                                <i class="ti ti-chart-dots me-1"></i>
                                Configurar Gráficos
                            </a>
                            <a href="<?php echo BASE_URL; ?>/admin/usuarios.php" 
                               class="btn btn-outline-secondary">
                                <i class="ti ti-users me-1"></i>
                                Usuarios
                            </a>
                        </div>
                    <?php endif; ?>
                </div>
            </div>
        </div>
        
        <!-- Selector de Período -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-3">
                        <label class="form-label">Período</label>
                    </div>
                    <div class="col-md-9">
                        <select class="form-select" id="periodo-selector" onchange="cambiarPeriodo(this.value)">
                            <?php foreach ($periodos as $p): ?>
                                <option value="<?php echo $p['ejercicio'] . '-' . $p['periodo']; ?>"
                                        <?php echo ($p['ejercicio'] == $ejercicio && $p['periodo'] == $periodo_mes) ? 'selected' : ''; ?>>
                                    <?php echo $p['nombre']; ?>
                                </option>
                            <?php endforeach; ?>
                        </select>
                    </div>
                </div>
            </div>
        </div>
        
        <?php if (empty($metricas) && empty($graficos_configurados)): ?>
            <!-- Estado vacío -->
            <div class="empty">
                <div class="empty-icon">
                    <i class="ti ti-database-off"></i>
                </div>
                <p class="empty-title">No hay métricas ni gráficos configurados</p>
                <p class="empty-subtitle text-muted">
                    Esta área no tiene métricas definidas ni gráficos configurados.
                </p>
                <?php if ($is_admin): ?>
                    <div class="empty-action">
                        <a href="<?php echo BASE_URL; ?>/admin/configurar-metricas.php?area=<?php echo $area_actual; ?>" 
                           class="btn btn-primary">
                            <i class="ti ti-plus me-1"></i>
                            Configurar Métricas
                        </a>
                    </div>
                <?php endif; ?>
            </div>
        <?php else: ?>
            
            <!-- Gráficos Dinámicos -->
            <?php if (!empty($graficos_configurados)): ?>
                <div class="row g-4 mb-4">
                    <?php foreach ($graficos_configurados as $grafico): ?>
                        <div class="<?php echo $grafico['ancho']; ?>">
                            <div class="card">
                                <div class="card-header">
                                    <h3 class="card-title">
                                        <?php echo htmlspecialchars($grafico['titulo']); ?>
                                    </h3>
                                    <?php if ($grafico['descripcion']): ?>
                                        <div class="card-actions">
                                            <span class="text-muted small" title="<?php echo htmlspecialchars($grafico['descripcion']); ?>">
                                                <i class="ti ti-info-circle"></i>
                                            </span>
                                        </div>
                                    <?php endif; ?>
                                </div>
                                <div class="card-body">
                                    <?php
                                    // Parsear configuración
                                    $config = json_decode($grafico['configuracion'], true);
                                    $tipo = $grafico['tipo'];
                                    
                                    // Preparar datos según el tipo de gráfico
                                    if ($tipo === 'bar' || $tipo === 'line' || $tipo === 'progress') {
                                        // Gráficos de 1 métrica
                                        $metrica_data = obtenerDatosMetrica(
                                            $config['metrica_id'], 
                                            $periodo['id'], 
                                            $metricaModel, 
                                            $valorModel
                                        );
                                        
                                        if ($metrica_data) {
                                            include BASE_PATH . "/components/charts/{$tipo}.php";
                                        } else {
                                            echo '<div class="alert alert-warning">Métrica no encontrada</div>';
                                        }
                                        
                                    } elseif ($tipo === 'comparison') {
                                        // Gráfico de comparación
                                        $metricas_data = [];
                                        foreach ($config['metricas'] as $m) {
                                            $metrica_data = obtenerDatosMetrica(
                                                $m['id'], 
                                                $periodo['id'], 
                                                $metricaModel, 
                                                $valorModel
                                            );
                                            if ($metrica_data) {
                                                $metricas_data[] = $metrica_data;
                                            }
                                        }
                                        
                                        if (count($metricas_data) >= 2) {
                                            include BASE_PATH . "/components/charts/comparison.php";
                                        } else {
                                            echo '<div class="alert alert-warning">No hay suficientes métricas para comparar</div>';
                                        }
                                        
                                    } elseif ($tipo === 'trend') {
                                        // Gráfico de tendencia
                                        $historico_data = obtenerHistoricoMetrica(
                                            $config['metrica_id'],
                                            $config['periodos'] ?? 6,
                                            $periodo['id'],
                                            $metricaModel,
                                            $periodoModel,
                                            $valorModel
                                        );
                                        
                                        if (!empty($historico_data)) {
                                            include BASE_PATH . "/components/charts/trend.php";
                                        } else {
                                            echo '<div class="alert alert-warning">No hay datos históricos disponibles</div>';
                                        }
                                    }
                                    ?>
                                </div>
                            </div>
                        </div>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
            
            <!-- Cards de Métricas (si no hay gráficos, mostrar cards tradicionales) -->
            <?php if (empty($graficos_configurados) && !empty($metricas)): ?>
                <div class="row g-4">
                    <?php foreach ($metricas as $metrica): ?>
                        <div class="col-md-6 col-lg-4">
                            <div class="card metric-card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="metric-icon me-3" style="background: <?php echo $area['color']; ?>20;">
                                            <i class="ti ti-<?php echo $metrica['icono'] ?? 'chart-bar'; ?>" 
                                               style="color: <?php echo $area['color']; ?>"></i>
                                        </div>
                                        <div class="flex-fill">
                                            <h3 class="metric-title mb-0">
                                                <?php echo htmlspecialchars($metrica['nombre']); ?>
                                            </h3>
                                        </div>
                                    </div>
                                    
                                    <div class="metric-value" style="color: <?php echo $area['color']; ?>">
                                        <?php 
                                        if ($metrica['valor'] !== null) {
                                            echo number_format(
                                                $metrica['valor'], 
                                                ($metrica['tipo_valor'] === 'decimal' || $metrica['tipo_valor'] === 'porcentaje') ? 2 : 0
                                            );
                                        } else {
                                            echo '<span class="text-muted">-</span>';
                                        }
                                        ?>
                                        <?php if ($metrica['unidad']): ?>
                                            <small class="text-muted ms-1"><?php echo $metrica['unidad']; ?></small>
                                        <?php endif; ?>
                                    </div>
                                    
                                    <?php if (isset($metrica['valor_anterior']) && $metrica['valor_anterior'] !== null && $metrica['valor'] !== null): ?>
                                        <?php
                                        $valor_anterior = $metrica['valor_anterior'] ?? 0;
$cambio = $metrica['valor'] - $valor_anterior;
$cambio_porcentaje = $valor_anterior > 0 
    ? (($metrica['valor'] - $valor_anterior) / $valor_anterior) * 100 
    : 0;
                                        ?>
                                        <div class="metric-change mt-2">
                                            <span class="badge bg-<?php echo $cambio >= 0 ? 'success' : 'danger'; ?>-lt">
                                                <i class="ti ti-<?php echo $cambio >= 0 ? 'trending-up' : 'trending-down'; ?> me-1"></i>
                                                <?php echo $cambio >= 0 ? '+' : ''; ?><?php echo number_format($cambio_porcentaje, 1); ?>%
                                            </span>
                                            <span class="text-muted small ms-2">vs período anterior</span>
                                        </div>
                                    <?php endif; ?>
                                </div>
                            </div>
                        </div>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
            
        <?php endif; ?>
        
    </div>
</div>

<script>
function cambiarPeriodo(periodo) {
    const area = <?php echo $area_actual; ?>;
    window.location.href = `?area=${area}&periodo=${periodo}`;
}
</script>

