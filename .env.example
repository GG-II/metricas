# ==========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==========================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env
# 2. Configura los valores según tu entorno
# 3. NUNCA subas el archivo .env a Git

DB_HOST=localhost
DB_NAME=metricas_it_dev
DB_USER=root
DB_PASS=tu_password_seguro_aqui
DB_CHARSET=utf8mb4

# ==========================================
# CONFIGURACIÓN DEL SISTEMA
# ==========================================
APP_NAME="Dashboard de Métricas IT"
APP_VERSION=2.0.0
TIMEZONE=America/Guatemala

# ==========================================
# CONFIGURACIÓN DE ENTORNO
# ==========================================
# Valores: development, staging, production
ENVIRONMENT=development

# ==========================================
# SEGURIDAD
# ==========================================
# Genera una clave de 32 caracteres aleatorios para sesiones
APP_KEY=

# ==========================================
# RUTAS (relativas al DocumentRoot)
# ==========================================
BASE_URL=/metricas-it
