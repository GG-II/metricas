# Sistema de Métricas - .gitignore

# Composer
vendor/
composer.lock

# Logs
logs/*.log
*.log

# Archivos de configuración local
.env
.env.local
.env.production
.env.development

# Scripts temporales y de desarrollo (en raíz del proyecto)
/add_remaining_charts.php
/cache-manager.php
/check_data.php
/check_status.php
/cleanup_database.php
/cleanup_test_data.php
/clear-cache.php
/create_test_environment.php
/debug-metricas.php
/fix_chart_configs.php
/recalcular_metricas.php
/run_global_migration.php
/run_migration.php
/run_migration_*.php
/run_seed_*.php
/seed_*.php
/test_*.php
/verify_*.php

# Uploads
public/assets/uploads/*
!public/assets/uploads/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Temporal
tmp/
temp/
*.tmp

# Cache
cache/
*.cache

# Backups
*.bak
*.backup
*.sql.gz

# Node modules (si se usa)
node_modules/

# Settings locales de Claude
.claude/settings.local.json
