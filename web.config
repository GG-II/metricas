<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <!-- ============================================ -->
        <!-- REDIRECCIÓN A CARPETA PUBLIC                 -->
        <!-- ============================================ -->
        <!-- Este archivo redirige todas las peticiones   -->
        <!-- de la raíz a la carpeta public/              -->
        <!-- ============================================ -->
        <rewrite>
            <rules>
                <rule name="Redirect to public folder" stopProcessing="true">
                    <match url="^(.*)$" />
                    <conditions logicalGrouping="MatchAll">
                        <!-- No redirigir si ya estamos en public/ -->
                        <add input="{REQUEST_URI}" pattern="^/public/" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="public/{R:1}" />
                </rule>
            </rules>
        </rewrite>

        <!-- ============================================ -->
        <!-- HANDLERS PHP                                 -->
        <!-- ============================================ -->
        <handlers>
            <add name="PHP_via_FastCGI"
                 path="*.php"
                 verb="GET,HEAD,POST,PUT,DELETE,OPTIONS"
                 modules="FastCgiModule"
                 scriptProcessor="C:\PHP\php-cgi.exe"
                 resourceType="Either"
                 requireAccess="Script" />
        </handlers>

        <!-- ============================================ -->
        <!-- DOCUMENTOS POR DEFECTO                       -->
        <!-- ============================================ -->
        <defaultDocument>
            <files>
                <clear />
                <add value="index.php" />
                <add value="login.php" />
            </files>
        </defaultDocument>

        <!-- ============================================ -->
        <!-- MANEJO DE ERRORES                            -->
        <!-- ============================================ -->
        <httpErrors errorMode="Detailed" existingResponse="PassThrough" />
    </system.webServer>
</configuration>
